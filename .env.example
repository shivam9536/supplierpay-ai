# ============================================
# SupplierPay AI — Environment Configuration
# ============================================
# Copy this to .env and fill in your values

# ── App ──────────────────────────────────────
APP_ENV=development
APP_PORT=8080
FRONTEND_URL=http://localhost:3000
MOCK_MODE=true

# ── Database ─────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=supplierpay
DB_PASSWORD=supplierpay_dev
DB_NAME=supplierpay
DB_SSLMODE=disable

# ── AWS ──────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Bedrock ──────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096

# ── AWS S3 ───────────────────────────────────
S3_BUCKET_NAME=supplierpay-invoices
S3_REGION=ap-south-1

# ── AWS SES ──────────────────────────────────
SES_SENDER_EMAIL=noreply@supplierpay.ai
SES_REGION=ap-south-1

# ── Pine Labs ────────────────────────────────
PINELABS_API_URL=https://sandbox.pinelabs.com/api/v1
PINELABS_API_KEY=
PINELABS_MERCHANT_ID=

# ── JWT ──────────────────────────────────────
JWT_SECRET=supplierpay-hackathon-secret-change-me
JWT_EXPIRY_HOURS=24
